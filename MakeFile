# Makefile for Device Provisioner
# Alternative build system to CMake

# Compiler and flags
CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -Wpedantic
LDFLAGS = -lcurl -lpthread -lstdc++fs

# Build configurations
DEBUG_FLAGS = -g -O0 -DDEBUG
RELEASE_FLAGS = -O3 -DNDEBUG

# Directories
BUILD_DIR = build
BIN_DIR = bin
SRC_DIR = .

# Target executable
TARGET = device_provisioner
SOURCE = device_provisioner.cpp

# Installation directory
PREFIX = /usr/local
INSTALL_DIR = $(PREFIX)/bin

# Colors for output
RED = \033[0;31m
GREEN = \033[0;32m
YELLOW = \033[1;33m
NC = \033[0m # No Color

# Default target
.PHONY: all
all: release

# Release build
.PHONY: release
release: CXXFLAGS += $(RELEASE_FLAGS)
release: $(BIN_DIR)/$(TARGET)
	@echo "$(GREEN)✓ Release build complete$(NC)"

# Debug build
.PHONY: debug
debug: CXXFLAGS += $(DEBUG_FLAGS)
debug: $(BIN_DIR)/$(TARGET)
	@echo "$(GREEN)✓ Debug build complete$(NC)"

# Create directories
$(BIN_DIR):
	@mkdir -p $(BIN_DIR)
	@echo "$(GREEN)✓ Created bin directory$(NC)"

# Build the executable
$(BIN_DIR)/$(TARGET): $(SOURCE) | $(BIN_DIR)
	@echo "$(YELLOW)Building $(TARGET)...$(NC)"
	$(CXX) $(CXXFLAGS) $< -o $@ $(LDFLAGS)
	@echo "$(GREEN)✓ Build successful: $@$(NC)"

# Install the executable
.PHONY: install
install: release
	@echo "$(YELLOW)Installing $(TARGET) to $(INSTALL_DIR)...$(NC)"
	@sudo install -m 755 $(BIN_DIR)/$(TARGET) $(INSTALL_DIR)
	@echo "$(GREEN)✓ Installed to $(INSTALL_DIR)/$(TARGET)$(NC)"

# Uninstall
.PHONY: uninstall
uninstall:
	@echo "$(YELLOW)Uninstalling $(TARGET)...$(NC)"
	@sudo rm -f $(INSTALL_DIR)/$(TARGET)
	@echo "$(GREEN)✓ Uninstalled$(NC)"

# Run the application (requires sudo)
.PHONY: run
run: release
	@echo "$(YELLOW)Running $(TARGET) (requires sudo)...$(NC)"
	@sudo $(BIN_DIR)/$(TARGET)

# Clean build artifacts
.PHONY: clean
clean:
	@echo "$(YELLOW)Cleaning build artifacts...$(NC)"
	@rm -rf $(BIN_DIR) $(BUILD_DIR)
	@echo "$(GREEN)✓ Clean complete$(NC)"

# Check dependencies
.PHONY: check-deps
check-deps:
	@echo "$(YELLOW)Checking dependencies...$(NC)"
	@command -v g++ >/dev/null 2>&1 || { echo "$(RED)✗ g++ is not installed$(NC)"; exit 1; }
	@echo "$(GREEN)✓ g++ found$(NC)"
	@command -v pkg-config >/dev/null 2>&1 || { echo "$(RED)✗ pkg-config is not installed$(NC)"; exit 1; }
	@echo "$(GREEN)✓ pkg-config found$(NC)"
	@pkg-config --exists libcurl || { echo "$(RED)✗ libcurl is not installed$(NC)"; exit 1; }
	@echo "$(GREEN)✓ libcurl found$(NC)"
	@echo "$(GREEN)✓ All dependencies satisfied$(NC)"

# Static analysis
.PHONY: analyze
analyze: 
	@echo "$(YELLOW)Running static analysis...$(NC)"
	@if command -v cppcheck >/dev/null 2>&1; then \
		cppcheck --enable=all --suppress=missingIncludeSystem $(SOURCE); \
		echo "$(GREEN)✓ Static analysis complete$(NC)"; \
	else \
		echo "$(YELLOW)⚠ cppcheck not installed, skipping static analysis$(NC)"; \
	fi

# Format code
.PHONY: format
format:
	@echo "$(YELLOW)Formatting code...$(NC)"
	@if command -v clang-format >/dev/null 2>&1; then \
		clang-format -i $(SOURCE); \
		echo "$(GREEN)✓ Code formatted$(NC)"; \
	else \
		echo "$(YELLOW)⚠ clang-format not installed, skipping formatting$(NC)"; \
	fi

# Build and run tests (placeholder for future test implementation)
.PHONY: test
test: debug
	@echo "$(YELLOW)Running tests...$(NC)"
	@echo "$(YELLOW)⚠ No tests implemented yet$(NC)"

# Show help
.PHONY: help
help:
	@echo "$(GREEN)Device Provisioner - Makefile Usage$(NC)"
	@echo ""
	@echo "Available targets:"
	@echo "  $(YELLOW)all$(NC)        - Build release version (default)"
	@echo "  $(YELLOW)release$(NC)    - Build optimized release version"
	@echo "  $(YELLOW)debug$(NC)      - Build debug version with symbols"
	@echo "  $(YELLOW)install$(NC)    - Install to system (requires sudo)"
	@echo "  $(YELLOW)uninstall$(NC)  - Remove from system (requires sudo)"
	@echo "  $(YELLOW)run$(NC)        - Build and run (requires sudo)"
	@echo "  $(YELLOW)clean$(NC)      - Remove build artifacts"
	@echo "  $(YELLOW)check-deps$(NC) - Verify dependencies are installed"
	@echo "  $(YELLOW)analyze$(NC)    - Run static analysis (requires cppcheck)"
	@echo "  $(YELLOW)format$(NC)     - Format code (requires clang-format)"
	@echo "  $(YELLOW)test$(NC)       - Run tests (placeholder)"
	@echo "  $(YELLOW)help$(NC)       - Show this help message"
	@echo ""
	@echo "Examples:"
	@echo "  $$ make              # Build release version"
	@echo "  $$ make debug        # Build debug version"
	@echo "  $$ make install      # Install to system"
	@echo "  $$ make run          # Build and run immediately"
	@echo "  $$ make clean        # Clean build files"

# Verbose build for debugging makefile issues
.PHONY: verbose
verbose: CXXFLAGS += -v
verbose: release

.DEFAULT_GOAL := all